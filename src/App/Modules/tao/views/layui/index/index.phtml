<script>
    if (tabs.activeLayHref === '') {
        tabs.activeLayHref = '<?= $indexWelcome ?>';
    }
    admin.util.layOn({
        message: function () {
            admin.layer.success('TODO 消息中心')
        },
        clear: function () {
            admin.ajax.get({
                url: '<?= $vv->urlModule("tao/user.index/clear", true) ?>'
            })
        },
        logout: function () {
            admin.ajax.get({
                url: '<?= $vv->urlModule("tao/user.index/logout", true) ?>'
            }, function (rst) {
                admin.cache.clear();
                setTimeout(function () {
                    location.href = rst.data || '/';
                }, 1000)
            })
        }
    })
    // 移动端：select 切换 sidebar
    $('#mobileSidebarSwitch').on('change', function () {
        var id = $(this).val();
        tabs.activeSidebar(id, true);
        tabs.tmpMenuId = id;
    });
</script>
