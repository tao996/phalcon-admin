    <?php
    $iconClass = match ($icon) {
        1, 6 => 'layui-icon-face-smile icon-success',
        3, 7 => 'layui-icon-about icon-warn',
        4    => 'layui-icon-lock icon-info',
        default => 'layui-icon-circle-close icon-error',
    };
    ?>
    <i class="layui-icon <?= $iconClass ?>"></i>
    <div class="msg"><?= $vv->html()->text($msg) ?></div>
    <div class="countdown">
        <span id="countdownNum"><?= $wait ?></span> 秒后自动跳转
    </div>
    <div class="btn-group">
        <a class="btn-primary" href="javascript:;" id="btnConfirm">立即跳转</a>
        <a class="btn-default" href="javascript:;" id="btnCancel">返回上一页</a>
    </div>
</div>

<?php
$vv->html()->outputFooters();
$vv->layui()->footer();
?>
<script>
    (function () {
        var countdown = <?= (int)$wait ?>;
        var url = '<?= isset($url) ? addslashes($url) : '' ?>';
        var timer = setInterval(function () {
            countdown--;
            document.getElementById('countdownNum').textContent = countdown;
            if (countdown <= 0) {
                clearInterval(timer);
                doRedirect();
            }
        }, 1000);

        function doRedirect() {
            if (!url) {
                history.back();
                return;
            }
            if (url === 'close') {
                admin.cache.remove('tabs');
                return;
            }
            var redirect = encodeURIComponent(location.href);
            location.href = url + (url.indexOf('?') >= 0 ? '&' : '?') + '_redirect=' + redirect;
        }

        document.getElementById('btnConfirm').onclick = function () {
            clearInterval(timer);
            doRedirect();
        };

        document.getElementById('btnCancel').onclick = function () {
            clearInterval(timer);
            var prev = location.href;
            history.back();
            setTimeout(function () {
                if (location.href === prev) {
                    location.href = '/';
                }
            }, 500);
        };
    })();
</script>
</body>
</html>
