#!/usr/bin/env php
<?php
/**
 * Phalcon Admin 部署工具
 *
 * 用法:
 *   php deploy server:init             # 检测环境并生成报告
 *   php deploy server:init -y          # 执行初始化（根据环境自动选择模式）
 *   php deploy server:init -y mode=host_nginx  # 强制宿主机 nginx 模式
 *   php deploy nginx:reload           # 验证配置语法并重载 Nginx（全局）
 *   php deploy app:init <project>      # 预览（无 -y）或执行部署（加 -y）
 *   php deploy app:upgrade <project>   # 更新已有项目
 *   php deploy app:restart <project>   # 重启项目 Docker 容器
 *   php deploy app:push <project>      # 推送本地配置到远程
 *   php deploy app:status <project>    # 查看项目容器状态
 *   php deploy app:nginx:add <project> # 为项目添加域名到 Router
 *   php deploy app:nginx:remove <project>  # 从 Router 移除域名
 *   php deploy db:proxy <project>      # SSH 隧道转发
 *   php deploy db:pma <project>        # 部署临时 phpMyAdmin
 *   php deploy db:pma-rm <project>     # 删除临时 phpMyAdmin
 *   php deploy --help                  # 显示帮助
 *
 * 参数:
 *   -y                   自动执行
 *   -key=value           命名参数
 *   env=prod             选择服务器配置文件 (server.{env}.php)
 *   mode=host_nginx      强制宿主机模式
 *   port=8071            手动指定项目 nginx 端口
 */

// ---------- 初始化 ----------

// 定义根路径
define('DEPLOY_BASE', __DIR__);
define('DEPLOY_SRC', DEPLOY_BASE . '/deploys/src');

// 加载 phpseclib（用于 SSH 连接）
$pharPath = DEPLOY_BASE . '/src/tao996/phar/phpseclib.phar';
if (file_exists($pharPath)) {
    require $pharPath;
} else {
    fwrite(STDERR, "错误: 未找到 phpseclib.phar\n");
    fwrite(STDERR, "预期路径: {$pharPath}\n");
    exit(1);
}

// 加载部署引擎
require DEPLOY_SRC . '/helpers.php';
require DEPLOY_SRC . '/Config.php';
require DEPLOY_SRC . '/SSH.php';
require DEPLOY_SRC . '/TemplateRenderer.php';
require DEPLOY_SRC . '/GitHelper.php';
require DEPLOY_SRC . '/RouterManager.php';
require DEPLOY_SRC . '/ProjectDeployer.php';
require DEPLOY_SRC . '/DbManager.php';

// ---------- 解析参数 ----------

$args = $_SERVER['argv'] ?? [];
$scriptName = array_shift($args); // 移除脚本名

// 分离命名参数（-key=value 或 --key=value）
$namedParams = [];
$positionalArgs = [];

foreach ($args as $arg) {
    if (str_starts_with($arg, '--')) {
        $parts = explode('=', substr($arg, 2), 2);
        $namedParams[$parts[0]] = $parts[1] ?? true;
    } elseif (str_starts_with($arg, '-') && !str_starts_with($arg, '--')) {
        $parts = explode('=', substr($arg, 1), 2);
        $namedParams[$parts[0]] = $parts[1] ?? true;
    } else {
        $positionalArgs[] = $arg;
    }
}

// ---------- 路由 ----------

function showHelp(): void
{
    echo <<<HELP
\033[36mPhalcon Admin 部署工具\033[0m

用法:
  php deploy \033[33m<命令>\033[0m [参数...] [-key=value]

命令:
  \033[33mserver:init\033[0m              检测服务器环境（默认只报告，加 -y 才执行）
  \033[33mserver:init -y\033[0m           执行初始化（自动选择 Docker Router 或宿主机 Nginx）
  \033[33mnginx:reload\033[0m             验证配置语法并重载 Nginx（全局）
  \033[33mnginx:log:error\033[0m          查看 Nginx 错误日志（--save 下载到本地）
  \033[33mnginx:log:access\033[0m         查看 Nginx 访问日志（--save 下载到本地）

  \033[33mapp:init\033[0m <项目名>         预览并部署项目（无 -y 生成配置到本地，加 -y 执行远程部署）
  \033[33mapp:upgrade\033[0m <项目名>      更新已有项目
  \033[33mapp:dc:restart\033[0m <项目名>   重启 Docker 容器（首次自动拉取镜像）
  \033[33mapp:dc:status\033[0m <项目名>    查看容器状态
  \033[33mapp:dc:log\033[0m <项目名>          查看全部容器日志
  \033[33mapp:dc:log:<容器名称>\033[0m <项目名>       查看容器日志
  \033[33mapp:push\033[0m <项目名>         推送本地配置文件到远程（覆盖已有配置）
  \033[33mapp:nginx:add\033[0m <项目名>    为项目添加域名到 Router
  \033[33mapp:nginx:remove\033[0m <项目名> 从 Router 移除域名

  \033[33mdb:proxy\033[0m <项目名>         SSH 隧道转发（本地 → 远程 MySQL）
  \033[33mdb:pma\033[0m <项目名>          部署临时 phpMyAdmin
  \033[33mdb:pma-rm\033[0m <项目名>       删除临时 phpMyAdmin
  \033[33m--help\033[0m                  显示此帮助

参数:
  env=prod              选择服务器配置文件 (server.prod.php)
  -y                    自动执行（server:init 默认只检测，加 -y 才安装；app:init 默认预览，加 -y 执行远程部署）
  mode=host_nginx       强制宿主机模式（仅 server:init -y 时生效）
  port=8071             手动指定项目 nginx 端口（宿主机模式 app:init 时可选）
  local=13306           SSH 隧道本地端口（db:proxy 时指定）
  host=13307            phpMyAdmin 宿主机端口（db:pma 时指定）
  --save                下载日志到本地（nginx:log:* 时使用）

示例:
  php deploy server:init              # 只检测环境
  php deploy server:init -y           # 检测 + 自动安装
  php deploy server:init -y mode=host_nginx  # 强制宿主机模式
  php deploy app:init myapp
  php deploy app:upgrade myapp
  php deploy app:dc:status myapp
  php deploy db:proxy myapp           # SSH 隧道到 MySQL
  php deploy db:proxy myapp local=13307 # 指定本地端口
  php deploy db:pma myapp             # 部署临时 phpMyAdmin
  php deploy db:pma myapp host=13308  # 指定宿主机端口
  php deploy db:pma-rm myapp          # 清理 phpMyAdmin

HELP;
}

$command = $positionalArgs[0] ?? '';

if ($command === '--help' || $command === '-h' || empty($command)) {
    showHelp();
    exit(0);
}

// ---------- 加载配置 ----------

// 确定服务器配置文件
$envSuffix = $namedParams['env'] ?? '';
$serverConfigFile = DEPLOY_BASE . '/deploys/server.php';
if ($envSuffix && file_exists(DEPLOY_BASE . "/deploys/server.{$envSuffix}.php")) {
    $serverConfigFile = DEPLOY_BASE . "/deploys/server.{$envSuffix}.php";
}

if (!file_exists($serverConfigFile)) {
    fwrite(STDERR, "错误: 服务器配置文件不存在: {$serverConfigFile}\n");
    fwrite(STDERR, "请先执行: cp deploys/server.example.php deploys/server.php\n");
    exit(1);
}

// ---------- 执行命令 ----------

// 处理 app:dc:log:<容器> 类命令
$container = '';
if (str_starts_with($command, 'app:dc:log:')) {
    $parts = explode(':', $command, 4);
    $container = $parts[3] ?? '';
    $command = 'app:dc:log';
    $namedParams['container'] = $container;
}

try {
    switch ($command) {
        case 'server:init':
            handleInitRouter($serverConfigFile, $namedParams);
            break;

        case 'nginx:reload':
            handleNginxReload($serverConfigFile);
            break;

        case 'nginx:log:error':
            handleNginxLog($serverConfigFile, 'error', $namedParams);
            break;

        case 'nginx:log:access':
            handleNginxLog($serverConfigFile, 'access', $namedParams);
            break;

        case 'app:init':
            $projectName = $positionalArgs[1] ?? '';
            if (empty($projectName)) {
                fwrite(STDERR, "错误: 请指定项目名\n用法: php deploy init <项目名>\n");
                exit(1);
            }
            handleInit($serverConfigFile, $projectName, $namedParams);
            break;

        case 'app:push':
            $projectName = $positionalArgs[1] ?? '';
            if (empty($projectName)) {
                fwrite(STDERR, "错误: 请指定项目名\n用法: php deploy app:push <项目名>\n");
                exit(1);
            }
            handleConfigPush($serverConfigFile, $projectName, $namedParams);
            break;

        case 'app:dc:restart':
            $projectName = $positionalArgs[1] ?? '';
            if (empty($projectName)) {
                fwrite(STDERR, "错误: 请指定项目名\n用法: php deploy app:dc:restart <项目名>\n");
                exit(1);
            }
            handleRestart($serverConfigFile, $projectName);
            break;

        case 'app:dc:status':
            $projectName = $positionalArgs[1] ?? '';
            if (empty($projectName)) {
                fwrite(STDERR, "错误: 请指定项目名\n用法: php deploy app:dc:status <项目名>\n");
                exit(1);
            }
            handleStatus($serverConfigFile, $projectName);
            break;

        case 'app:dc:log':
            $projectName = $positionalArgs[1] ?? '';
            if (empty($projectName)) {
                fwrite(STDERR, "错误: 请指定项目名\n用法: php deploy app:dc:log[:<容器>] <项目名>\n");
                exit(1);
            }
            $container = $namedParams['container'] ?? '';
            handleDcLog($serverConfigFile, $projectName, $container);
            break;

        case 'app:upgrade':
            $projectName = $positionalArgs[1] ?? '';
            if (empty($projectName)) {
                fwrite(STDERR, "错误: 请指定项目名\n用法: php deploy app:upgrade <项目名>\n");
                exit(1);
            }
            handleUpgrade($serverConfigFile, $projectName, $namedParams);
            break;

        case 'app:nginx:add':
            $projectName = $positionalArgs[1] ?? '';
            if (empty($projectName)) {
                fwrite(STDERR, "错误: 请指定项目名\n用法: php deploy app:nginx:add <项目名>\n");
                exit(1);
            }
            handleNginxAdd($serverConfigFile, $projectName, $namedParams);
            break;

        case 'app:nginx:remove':
            $projectName = $positionalArgs[1] ?? '';
            if (empty($projectName)) {
                fwrite(STDERR, "错误: 请指定项目名\n用法: php deploy app:nginx:remove <项目名>\n");
                exit(1);
            }
            handleNginxRemove($serverConfigFile, $projectName);
            break;

        case 'app:dc:status':
            $projectName = $positionalArgs[1] ?? '';
            if (empty($projectName)) {
                fwrite(STDERR, "错误: 请指定项目名\n用法: php deploy app:dc:status <项目名>\n");
                exit(1);
            }
            handleStatus($serverConfigFile, $projectName);
            break;

        case 'db:proxy':
            $projectName = $positionalArgs[1] ?? '';
            if (empty($projectName)) {
                fwrite(STDERR, "错误: 请指定项目名\n用法: php deploy db:proxy <项目名> [local=端口]\n");
                exit(1);
            }
            handleDbProxy($serverConfigFile, $projectName, $namedParams);
            break;

        case 'db:pma':
            $projectName = $positionalArgs[1] ?? '';
            if (empty($projectName)) {
                fwrite(STDERR, "错误: 请指定项目名\n用法: php deploy db:pma <项目名> [host=端口]\n");
                exit(1);
            }
            handleDbPma($serverConfigFile, $projectName, $namedParams);
            break;

        case 'db:pma-rm':
            $projectName = $positionalArgs[1] ?? '';
            if (empty($projectName)) {
                fwrite(STDERR, "错误: 请指定项目名\n用法: php deploy db:pma-rm <项目名>\n");
                exit(1);
            }
            handleDbPmaRm($serverConfigFile, $projectName);
            break;

        default:
            fwrite(STDERR, "错误: 未知命令 '{$command}'\n");
            fwrite(STDERR, "用法: php deploy --help\n");
            exit(1);
    }
} catch (Throwable $e) {
    fwrite(STDERR, "\033[31m错误: {$e->getMessage()}\033[0m\n");
    fwrite(STDERR, "文件: {$e->getFile()}:{$e->getLine()}\n");
    exit(1);
}

exit(0);

// ---------- 命令处理函数 ----------

function handleInitRouter(string $serverConfigFile, array $params): void
{
    $config = new DeployConfig();
    $config->loadServer($serverConfigFile);

    $autoExecute = isset($params['y']) && $params['y'] === true;
    $modeOverride = $params['mode'] ?? '';

    $ssh = new DeploySSH($config->getSshConfig());
    $ssh->connect();

    $routerConfig = $config->getMerged()['router'] ?? [];
    if ($modeOverride) {
        $routerConfig['mode'] = $modeOverride;
    }

    $router = new RouterManager($ssh, $routerConfig);
    $chosenMode = $router->initRouter($autoExecute);

    $ssh->disconnect();

    // 保存模式到本地配置缓存（供后续 init 命令使用）
    if ($chosenMode !== null) {
        $cacheDir = deploy_base_path() . '/.cache';
        if (!is_dir($cacheDir)) {
            mkdir($cacheDir, 0755, true);
        }
        file_put_contents($cacheDir . '/mode.txt', $chosenMode);
        deploy_log("模式已缓存: {$chosenMode}", 'info');
    }
}

function handleInit(string $serverConfigFile, string $projectName, array $params): void
{
    $config = new DeployConfig();
    $config->loadServer($serverConfigFile);
    $config->loadProject($projectName);

    // 传递模式参数
    $options = [];
    if (isset($params['mode'])) {
        $options['mode'] = $params['mode'];
    }
    if (isset($params['port'])) {
        $options['nginxPort'] = (int)$params['port'];
    }

    $deployer = new ProjectDeployer($config);

    // 无 -y 时进入预览模式（仅本地生成配置文件供检查）
    if (!isset($params['y'])) {
        $deployer->preview($options);
        return;
    }

    // 有 -y 时执行完整部署，优先使用本地已生成的配置文件
    $deployer->init($options, true);
}

function handleConfigPush(string $serverConfigFile, string $projectName, array $params): void
{
    $config = new DeployConfig();
    $config->loadServer($serverConfigFile);
    $config->loadProject($projectName);

    $deployer = new ProjectDeployer($config);
    $deployer->pushConfig();
}

function handleRestart(string $serverConfigFile, string $projectName): void
{
    $config = new DeployConfig();
    $config->loadServer($serverConfigFile);
    $config->loadProject($projectName);

    $deployer = new ProjectDeployer($config);
    $deployer->restart();
}

function handleNginxReload(string $serverConfigFile): void
{
    deploy_log("=== Nginx 重载 ===", 'step');

    $config = new DeployConfig();
    $config->loadServer($serverConfigFile);

    $ssh = new DeploySSH($config->getSshConfig());
    $ssh->connect();

    $router = new RouterManager($ssh, $config->getMerged()['router'] ?? []);
    $router->validateAndReload();

    $ssh->disconnect();
}

function handleNginxLog(string $serverConfigFile, string $type, array $params): void
{
    deploy_log("=== Nginx 日志: {$type} ===", 'step');

    $config = new DeployConfig();
    $config->loadServer($serverConfigFile);

    $ssh = new DeploySSH($config->getSshConfig());
    $ssh->connect();

    $router = new RouterManager($ssh, $config->getMerged()['router'] ?? []);
    $download = isset($params['save']);
    $router->nginxLog($type, $download);

    $ssh->disconnect();
}

function handleUpgrade(string $serverConfigFile, string $projectName, array $params): void
{
    $config = new DeployConfig();
    $config->loadServer($serverConfigFile);
    $config->loadProject($projectName);

    $options = [];
    if (isset($params['mode'])) {
        $options['mode'] = $params['mode'];
    }
    if (isset($params['port'])) {
        $options['nginxPort'] = (int)$params['port'];
    }

    $deployer = new ProjectDeployer($config);
    $deployer->upgrade($options);
}

function handleNginxAdd(string $serverConfigFile, string $projectName, array $params): void
{
    $config = new DeployConfig();
    $config->loadServer($serverConfigFile);
    $config->loadProject($projectName);

    $domains = $config->getDomains();
    if (empty($domains)) {
        deploy_log('项目未配置域名，跳过', 'warn');
        return;
    }

    $ssh = new DeploySSH($config->getSshConfig());
    $ssh->connect();

    $routerConfig = $config->getMerged()['router'] ?? [];
    if (isset($params['mode'])) {
        $routerConfig['mode'] = $params['mode'];
    }

    $router = new RouterManager($ssh, $routerConfig);
    $mode = $params['mode'] ?? null;
    $port = isset($params['port']) ? (int)$params['port'] : null;
    if ($port === null) {
        // 从项目配置读取 nginxPort
        $merged = $config->getMerged();
        $port = $merged['project']['nginxPort'] ?? null;
    }
    $router->addDomain($projectName, $domains, false, $mode, $port);

    $ssh->disconnect();
}

function handleNginxRemove(string $serverConfigFile, string $projectName): void
{
    $config = new DeployConfig();
    $config->loadServer($serverConfigFile);
    $config->loadProject($projectName);

    $ssh = new DeploySSH($config->getSshConfig());
    $ssh->connect();

    $router = new RouterManager($ssh, $config->getMerged()['router'] ?? []);
    $router->removeDomain($projectName);

    $ssh->disconnect();
}

function handleStatus(string $serverConfigFile, string $projectName): void
{
    $config = new DeployConfig();
    $config->loadServer($serverConfigFile);
    $config->loadProject($projectName);

    $deployer = new ProjectDeployer($config);
    $deployer->status();
}

function handleDcLog(string $serverConfigFile, string $projectName, string $service): void
{
    $config = new DeployConfig();
    $config->loadServer($serverConfigFile);
    $config->loadProject($projectName);

    $deployer = new ProjectDeployer($config);
    $deployer->dcLog($service);
}

function handleDbProxy(string $serverConfigFile, string $projectName, array $params): void
{
    $config = new DeployConfig();
    $config->loadServer($serverConfigFile);

    $localPort = isset($params['local']) ? (int)$params['local'] : 13306;

    $db = new DbManager($config);
    $db->proxyTunnel($projectName, $localPort);
}

function handleDbPma(string $serverConfigFile, string $projectName, array $params): void
{
    $config = new DeployConfig();
    $config->loadServer($serverConfigFile);

    $hostPort = isset($params['host']) ? (int)$params['host'] : 13307;

    $db = new DbManager($config);
    $db->deployPhpMyAdmin($projectName, $hostPort);
}

function handleDbPmaRm(string $serverConfigFile, string $projectName): void
{
    $config = new DeployConfig();
    $config->loadServer($serverConfigFile);

    $db = new DbManager($config);
    $db->removePhpMyAdmin($projectName);
}
