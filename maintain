             * @var string
             */
            public string $path_prod_config_file = '';
            /**
             * nginx 站点返回，默认 `PATH_ROOT.prod/default/$projectName.conf`
             * @var string
             */
            public string $path_prod_host_file = '';
            public string $path_prod_logs = PATH_ROOT . 'prod/logs/';
            public array $files = [
                '.env.example',
                'docker-compose.example.yaml',
                'php/php.example.ini',
                'php/supervisord.example.conf',
                'src/.env.example',
                'src/config/config.example.php',
                'src/config/project.example.php',
                'src/config/migration.example.php',
                'nginx/sites/default.example.conf', // 如果使用这个文件，则需要修改 docker-compose.yaml
            ];
            public array $nginxFiles = []; // 站点配置
            public G $g;
            /**
             * ssh.php 的配置信息
             * @return array{ip:string,port:int,username:string,password:string,public_ssh_key:string,private_ssh_key:string,path:string,nginx:string,
             *     certs:array{key:string,pem:string},hosts:array{string}}
             */
            private array $config = [];
            public string $remotePhalconAdminPath = '';
            public string $remoteNginxConf = '';

            public function __construct(G $g)
            {
                $this->g = $g;
                $this->dir = $g->getArgsWithKey('dir', 'default');
                $this->path_prod_save = $this->path_prod . $this->dir . '/';
                $this->path_prod_host_file = $this->path_prod_save . $this->getProjectName() . '.conf';
                $this->path_prod_config_file = $this->path_prod_save . 'ssh.php';

                $this->nginxFiles = [
                    ['nginx/host.example.conf', $this->getProjectName() . '.conf'],
                    ['nginx/host.location.example.conf', $this->getProjectName() . '.location.conf']
                ];
            }

            /**
             * 获取 `$this->files[i]` 保存在 prod 目录时的文件路径
             * @param array{string,string}|string $file
             * @param string|null $localPath 本地保存目录，默认为 `$this->path_prod_save`
             * @return string
             */
            public function getLocalFile(array|string $file, string $localPath = null): string
            {
                if (is_null($localPath)) {
                    $localPath = $this->path_prod_save;
                }
                if (is_array($file)) {
                    return $localPath . $file[1];
                }
                return $localPath . str_replace('/', '_', str_replace('.example', '', $file));
            }

            /**
             * 获取 `$this->files[i]` 在远程文件路径
             * @param array{string,string}|string $file
             * @param string|null $remotePath 远程对应的目录，默认来自 ssh.php->path
             * @return string 示例 `xxx/.env` 或者 `xxx/src/config/config.php`
             */
            public function getRemoteFile(array|string $file, string $remotePath = null): string
            {
                if (is_null($remotePath)) {
                    $remotePath = $this->remotePhalconAdminPath;
                }
                if (is_array($file)) {
                    return $remotePath . $file[1];
                }
                return $remotePath . str_replace('.example', '', $file);
            }

            /**
             * @return array{ip:string,port:int,username:string,password:string,public_ssh_key:string,private_ssh_key:string,path:string,nginx:string,
             *     certs:array{key:string,pem:string},hosts:array{string}}
             */
            public function getConfig(): array
            {
                if (empty($this->config)) {
                    if (!file_exists($this->path_prod_save)) {
                        die('目录不存在 ' . $this->path_prod_save . PHP_EOL);
                    }
                    $this->config = include_once $this->path_prod_config_file;
                    $this->remotePhalconAdminPath = rtrim($this->config['path'], '/') . '/';
                    $this->remoteNginxConf = rtrim($this->config['nginx'] ?? '/etc/nginx/cond.f', '/') . '/';
                }
                return $this->config;
            }

            public function getProjectName(): string
            {
                static $project = '';
                if (empty($project)) {
                    if (file_exists($this->path_prod_config_file)) {
                        if ($path = $this->getConfigWith('path', '')) {
                            $project = basename($path);
                        } else {
                            $project = $this->g->projectName;
                        }
                    } else {
                        $project = $this->g->projectName;
                    }
                }
                return $project;
            }

            public function getConfigWith($key, $default = ''): mixed
            {
                return $this->getConfig()[$key] ?? $default;
            }

            public function getCerts(): array
            {
                $certs = [];
                foreach ($this->config['certs'] ?? [] as $cert) {
                    $file = PATH_ROOT . 'nginx/ssl/' . $cert;
                    if (is_file($file) && file_exists($file)) {
                        $certs[] = $cert;
                    }
                }
                return $certs;
            }

            public function getHosts()
            {
                return $this->config['hosts'] ?? [];
            }

            public function createConfig(): void
            {
                $data = SshData;
                if (file_exists($this->path_prod_config_file)) {
                    $data = array_merge($data, include_once $this->path_prod_config_file);
                }
                $this->updateConfigFile($data);
            }

            public function updateConfigFile($data): void
            {
                file_put_contents($this->path_prod_config_file, '<?php return ' . var_export($data, true) . ';');
            }

            // 项目最新上传的时间
            public function getProjectMtime($project)
            {
                $projects = $this->getConfigWith('projects', []);
                return $projects[$project] ?? 0;
            }

            public function updateProjectMtime($project): void
            {
                $projects = $this->getConfigWith('projects', []);
                $projects[$project] = time();
                $this->config['projects'] = $projects;
                $this->updateConfigFile($this->config);
            }

            public function hasFilesInSaveDir(): bool
            {
                if (is_dir($this->path_prod_save)) {
                    return !empty(glob($this->path_prod_save . '*'));
                }
                return false;
            }

            public function createProdSaveDir(): void
            {
                if (is_dir($this->path_prod_save)) {
                    $hasFiles = glob($this->path_prod_save . '*');
                    if ($this->g->hasArgsWithKey('c')) {
                        if ($hasFiles && !$this->g->hasArgsWithKey('y')) {
                            die('{prod/' . $this->dir . '} 目录不为空；如需覆盖请追加参数 -y' . PHP_EOL);
                        }
                    } elseif (!$hasFiles) {
                        die('{prod/' . $this->dir . '} 目录为空，请先使用参数 -c 使用' . PHP_EOL);
                    }
                } else {
                    mkdir($this->path_prod_save);
                }
            }

            public function createFiles(): void
            {
                foreach (array_merge($this->files, $this->nginxFiles) as $file) {
                    if (is_string($file)) {
                        $toName = str_replace('.example', '', $file);
                    } else {
                        $toName = $file[1];
                        $file = $file[0];
                    }
                    $pathToName = $this->path_prod_save . str_replace('/', '_', $toName);
                    if (copy(PATH_ROOT . $file, $pathToName)) {
                        echo '复制成功 {', $toName . '}', PHP_EOL;
                    } else {
                        echo '复制失败 {', $toName . '}', PHP_EOL;
                        die();
                    }
                }
            }
        }

        $action = new ActionProd($g);
        $action->createProdSaveDir();

        if ($g->hasArgsWithKey('c')) {
            $type = $g->getArgsWithKey('c');
            if ($type == '*' || !$action->hasFilesInSaveDir()) {
                $action->createFiles();
            }
            $action->createConfig();

            echo "生成完毕，请修改你的 ssh.php，然后再次执行命令 `php maintain prod -r -y`，将自动更新配置", PHP_EOL;
        } elseif ($g->hasArgsWithKey('r')) {
            class ActionProdReplace
            {

                public ActionProd $prod;

                public function __construct(ActionProd $prod)
                {
                    $this->prod = $prod;
                    if (!file_exists($this->prod->path_prod_save . 'ssh.php')) {
                        die('ssh.php 文件不存在');
                    }
                    $this->prod->getConfig();
                }

                // 更改 host 文件中的 xxx.test
                function replaceNginxHost(): void
                {
                    $hostContent = file_get_contents($this->prod->path_prod_host_file);

                    $domains = $this->prod->getHosts();

                    // phalcon-admin.conf
                    // 1。替换域名
                    if ($domains) {
                        $dbDomains = array_map(function ($domain) {
                            return str_starts_with($domain, 'www.')
                                ? str_replace('www.', 'www.db-', $domain)
                                : 'db-' . $domain;
                        }, $domains);
                        $hostContent = str_replace('db-xxx.test', join(' ', $dbDomains), $hostContent);
                        $hostContent = str_replace('xxx.test', join(' ', $domains), $hostContent);
                        echo '替换域名成功 {', $this->prod->getProjectName(), '.conf}', PHP_EOL;
                    }
                    $phpmyadminPort = $_ENV['PHPMYADMIN_PORT'] ?? 0;
                    if ($phpmyadminPort > 0) {
                        $hostContent = str_replace(':5456', ':' . $phpmyadminPort, $hostContent);
                        echo '替换 db 端口成功', PHP_EOL;
                    }
                    // 2。替换 include
                    $hostContent = str_replace(
                        'include host.location.example.conf;',
                        'include conf.d/' . $this->prod->getProjectName() . '.location.conf',
                        $hostContent
                    );
                    // 3. 替换证书
                    $certs = $this->prod->getCerts();
                    if ($certs) {
                        if (!empty($certs['key'])) {
                            $hostContent = str_replace('xxx.key', $certs['key'], $hostContent);
                            echo '替换 key 证书成功', PHP_EOL;
                        }
                        if (!empty($certs['pem'])) {
                            $hostContent = str_replace('xxx.pem', $certs['pem'], $hostContent);
                            echo '替换 pem 证书成功', PHP_EOL;
                        }
                    }
                    file_put_contents($this->prod->path_prod_host_file, $hostContent);

                    // phalcon-admin.location.conf
                    if ($port = $this->getPort()) {
                        $path_location_file = $this->prod->path_prod_save . $this->prod->g->projectName . '.location.conf';
                        $locationContent = file_get_contents($path_location_file);
                        $locationContent = str_replace(':8071', ':' . $port, $locationContent);
                        file_put_contents($path_location_file, $locationContent);
                        echo '替换端口成功 {', $this->prod->g->projectName . '.location.conf', '}', PHP_EOL;
                    }
                }

                public function getPort(): int
                {
                    $port = intval($this->prod->g->maintainData['port'] ?? 0);
                    return $port > 0 && $port != 8071 ? $port : 0;
                }

                public function replaceEnv(): void
                {
                    if ($port = $this->getPort()) {
                        $envContent = file_get_contents($this->prod->path_prod_save . '.env');
                        $envContent = str_replace('OPEN_PORT=8071', 'OPEN_PORT=' . $port, $envContent);
                        file_put_contents($this->prod->path_prod_save . '.env', $envContent);
                    }
                }
            }

            $replace = new ActionProdReplace($action);
            $replace->replaceEnv();
            $replace->replaceNginxHost();

            echo '替换完成', PHP_EOL;
        }

        class ActionProdServer
        {
            // https://phpseclib.com/docs/auth

            public array $config;

            public function __construct(array $config)
            {
                $this->config = $config;
                $this->validate();
                include_once PATH_SRC . 'tao996/phar/phpseclib.phar';
            }

            private function validate(): void
            {
                if (empty($this->config['path'])) {
                    die('必须指定远程保存地址 ssh.php->path');
                }
                if (empty($this->config['ip'])) {
                    die('必须指定 ssh ip 地址' . PHP_EOL);
                } elseif (empty($this->config['username'])) {
                    die('必须指定 ssh username' . PHP_EOL);
                } elseif (empty($this->config['password']) && empty($this->config['private_ssh_key'])) {
                    die('必须指定密码或者登录证书');
                }
            }

            private function sftp()
            {
                static $sftp = null;
                if (is_null($sftp)) {
                    $sftp = new phpseclib3\Net\SFTP($this->config['ip']);
                    if (!empty($this->config['password'])) {
                        if (!$sftp->login($this->config['username'], $this->config['password'])) {
                            die('SFTP 密码登录失败');
                        }
                    } else {
                        $key = PublicKeyLoader::load(
                            file_get_contents($this->config['private_ssh_key'])
                        );
                        if (!$sftp->login($this->config['username'], $key)) {
                            die('SFTP Public Key 登录失败');
                        }
                    }
                }
                return $sftp;
            }

            private function ssh2()
            {
                static $ssh = null;
                if (is_null($ssh)) {
                    $ssh = new SSH2($this->config['ip']);
                    if (!empty($this->config['password'])) {
                        if (!$ssh->login($this->config['username'], $this->config['password'])) {
                            die("SSH2 validation failed using Username: " . $this->config['username'] . " (specify valid password)");
                        }
                    } else {
                        $key = PublicKeyLoader::load(
                            file_get_contents($this->config['private_ssh_key'])
                        );
                        if (!$ssh->login(
                            $this->config['username'],
                            $key
                        )) {
                            die("SSH2 validation failed using Username: " . $this->config['username'] . " (specify valid SSH keys or check your SSH key path)");
                        }
                    }
                }
                return $ssh;
            }


            /**
             * @param $command
             * @return string|false
             */
            public function sendCommand($command): bool|string
            {
                return $this->ssh2()->exec($command);
            }


            public function sendFile($local_file, $remote_file, $print = true): bool
            {
                if (!file_exists($local_file)) {
                    die('文件不存在 {' . $local_file . '}' . PHP_EOL);
                }
                $remote_dir = dirname($remote_file);
                if (!$this->sftp()->is_dir($remote_dir)) {
                    $this->createRemoteDirectoryRecursively($this->sftp(), $remote_dir);
                }
                $rst = $this->sftp()->put($remote_file, $local_file, SFTP::SOURCE_LOCAL_FILE);

                if ($print) {
                    if ($rst) {
                        echo '上传成功 {', $remote_file, '}', PHP_EOL;
                    } else {
                        echo '本地文件:', $local_file, PHP_EOL;
                        echo '远程文件:', $remote_file, PHP_EOL;
                        throw new \Exception('上传失败');
                    }
                }
                return $rst;
            }


            // 递归创建目录
            private function createRemoteDirectoryRecursively(SFTP $sftp, string $directory): void
            {
                $parentDir = dirname($directory);
                if ($parentDir !== '.' && !$sftp->is_dir($parentDir)) {
                    $this->createRemoteDirectoryRecursively($sftp, $parentDir);
                }
                if (!$sftp->is_dir($directory)) {
                    $sftp->mkdir($directory);
                }
            }

            /**
             * 获取文件
             */
            public function recvFile($remote_file, $local_file, $print = true): bool
            {
                $rst = $this->sftp()->get($remote_file, $local_file);
                if ($print) {
                    if ($rst) {
                        echo '获取成功 {', $remote_file, '}', PHP_EOL;
                        echo '   =>{', $local_file, '}', PHP_EOL;
                    } else {
                        echo '获取失败 {', $remote_file, '}', PHP_EOL;
                    }
                }

                return $rst;
            }

            /**
             * 移除文件
             */
            public function delFile($remote_file, $print = true): bool
            {
                $rst = $this->sftp()->delete($remote_file);
                if ($print) {
                    if ($rst) {
                        echo '移除成功 {', $remote_file, '}', PHP_EOL;
                    } else {
                        echo '移除失败 {', $remote_file . '}', PHP_EOL;
                    }
                }
                return $rst;
            }

            private function skipDownloadFile($file): bool
            {
                return in_array($file, ['.', '..', '.gitignore']);
            }

            public function downloadDir($remote_dir, $local_dir): void
            {
                $remote_dir = rtrim($remote_dir, '/') . '/';
                $local_dir = rtrim($local_dir, '/') . '/';

                $sftp = $this->sftp();
                if ($remoteList = $sftp->nlist($remote_dir)) {
                    foreach ($remoteList as $item) {
                        if (!$this->skipDownloadFile($item)) {
                            if ($sftp->is_dir($remote_dir . $item)) {
                                $localSubDir = $local_dir . $item;
                                if (!is_dir($localSubDir)) {
                                    mkdir($localSubDir, 0777, true);
                                }
                                // 递归下载
                                $this->downloadDirectoryRecursive($sftp, $remote_dir . $item, $localSubDir);
                            } else {
                                // 直接下载
                                $this->recvFile($remote_dir . $item, $local_dir . $item);
                            }
                        }
                    }
                }
            }

            private function downloadDirectoryRecursive(SFTP $sftp, string $remoteSubDir, string $localSubDir): void
            {
                $remoteList = $sftp->nlist($remoteSubDir);
                if ($remoteList) {
                    foreach ($remoteList as $item) {
                        if (!$this->skipDownloadFile($item)) {
                            if ($sftp->is_dir($remoteSubDir . $item)) {
                                $newLocalSubDir = $localSubDir . $item;
                                if (!is_dir($newLocalSubDir)) {
                                    mkdir($newLocalSubDir, 0777, true);
                                }
                                $this->downloadDirectoryRecursive($sftp, $remoteSubDir . $item, $newLocalSubDir);
                            } else {
                                $localFilePath = $localSubDir . $item;
                                $remoteFilePath = $remoteSubDir . $item;
                                $this->recvFile($remoteFilePath, $localFilePath);
                            }
                        }
                    }
                }
            }
        }

        if ($g->hasArgsWithKey('u')) {
            $ssh = new ActionProdServer($action->getConfig());
            echo '待上传目录: prod/', $action->dir, PHP_EOL;

            $uValue = $g->getArgsWithKey('u', '*');

            if (in_array($uValue, ['*', 'app'])) {
                echo '准备上传项目配置文件...', PHP_EOL;
                foreach ($action->files as $file) {
                    $local_file = $action->getLocalFile($file);
                    $remote_file = $action->getRemoteFile($file);
                    $ssh->sendFile($local_file, $remote_file);
                }
            }
            if (in_array($uValue, ['*', 'nginx'])) {
                if (empty($ssh->sendCommand('which nginx'))) {
                    die("nginx 还没有安装作" . PHP_EOL);
                }
                echo '准备上传站点文件到 nginx...', PHP_EOL;

                foreach ($action->nginxFiles as $files) {
                    $ssh->sendFile(
                        $action->path_prod_save . $files[1],
                        $action->remoteNginxConf . $files[1]
                    );
                }

                echo '准备上传证书到 nginx...', PHP_EOL;
                foreach ($action->getCerts() as $cert) {
                    $ssh->sendFile(
                        PATH_NGINX_SSL . $cert,
                        $action->remoteNginxConf . $cert
                    );
                }
            }
            if (in_array($uValue, ['*', 'hosts', 'host'])) {
                echo '准备处理 /etc/hosts...', PHP_EOL;
                $content = $ssh->sendCommand('cat /etc/hosts');
                $appendHosts = [];
                foreach ($action->getHosts() as $host) {
                    if (!str_contains($content, $host)) {
                        $appendHosts[] = '127.0.0.1 ' . $host;
                    }
                }
                if (!empty($appendHosts)) {
                    $cmd = 'echo "' . join(PHP_EOL, $appendHosts) . PHP_EOL . '" >> /etc/hosts';
                    $ssh->sendCommand($cmd);
                    echo '写入完成 /etc/hosts', PHP_EOL;
                }
            }
        } elseif ($g->hasArgsWithKey('del')) {
            $ssh = new ActionProdServer($action->getConfig());

            $dValue = $g->getArgsWithKey('del', '*');
            if (in_array($dValue, ['*', 'app'])) {
                echo '准备移除项目配置文件...', PHP_EOL;
                foreach ($action->files as $file) {
                    $remote_file = $action->getRemoteFile($file);
                    $ssh->delFile($remote_file);
                }
            }
            if (in_array($dValue, ['*', 'nginx'])) {
                echo '准备移除配置到 nginx 的文件...', PHP_EOL;
                foreach ($action->nginxFiles as $files) {
                    $remote_file = $action->remoteNginxConf . $files[1];
                    $ssh->delFile($remote_file);
                }
                if ($certs = $action->getCerts()) {
                    echo '准备移除配置到 nginx 的证书...', PHP_EOL;
                    foreach ($certs as $cert) {
                        $remote_file = $action->remoteNginxConf . $cert;
                        $ssh->delFile($remote_file);
                    }
                }
            }
            if (in_array($dValue, ['*', 'hosts', 'host'])) {
                echo '准备移除 /etc/hosts 域名配置信息 ...', PHP_EOL;
                $hosts = $action->getHosts();
                if (!empty($hosts)) {
                    $content = $ssh->sendCommand('cat /etc/hosts');
                    if (str_contains($content, '"')) {
                        die('/etc/hosts 中包含双引号，请手动替换' . PHP_EOL);
                    }
                    foreach ($hosts as $host) {
                        $content = str_replace('127.0.0.1 ' . $host, '', $content);
                    }
                    $content = preg_replace('/\n{2,}/', "\n", $content);
                    $cmd = 'echo "' . $content . '" >> /etc/hosts';
                    $ssh->sendCommand($cmd);
                    echo '更新完成 /etc/hosts', PHP_EOL;
                }
            }
        } elseif ($g->hasArgsWithKey('log')) {
            echo '准备下载日志...', PHP_EOL;
            if ($logs = $action->getConfigWith('logs', [])) {
                $pathLog = $action->path_prod_logs . $action->dir . '/' . date('Ymd') . '/';
                if (!file_exists($pathLog)) {
                    mkdir($pathLog, 0777, true);
                }
                $ssh = new ActionProdServer($action->getConfig());
                foreach ($logs as $log) {
                    if (is_string($log)) {
                        $remote_file = $action->remotePhalconAdminPath . $log;
                        $local_file = $pathLog . str_replace('/', '_', $log);
                        $ssh->recvFile($remote_file, $local_file);
                    } elseif (is_array($log)) {
                        $ssh->downloadDir($action->remotePhalconAdminPath . $log[0], $pathLog);
                    }
                }
            } else {
                echo '没有配置下载日志...', PHP_EOL;
            }
        } elseif ($g->hasArgsWithKey('d')) { // 备份远程的配置文件
            $ssh = new ActionProdServer($action->getConfig());
            echo '备份项目配置文件...', PHP_EOL;
            $pathBackup = rtrim($action->path_prod_save, '/') . '_' . date('Ymd') . '/';
            if (!file_exists($pathBackup)) {
                mkdir($pathBackup);
            }

            foreach ($action->files as $file) {
                $remote_file = $action->getRemoteFile($file);
                $local_file = $action->getLocalFile($file, $pathBackup);
                $ssh->recvFile($remote_file, $local_file);
            }
            echo '备份 nginx 站点文件...', PHP_EOL;
            foreach ($action->nginxFiles as $files) {
                $ssh->recvFile(
                    $action->remoteNginxConf . $files[1],
                    $pathBackup . $files[1]
                );
            }
            if ($backups = $action->getConfigWith('backup', [])) {
                echo '备份自定义项目文件...', PHP_EOL;
                foreach ($backups as $file) {
                    $local_file = $pathBackup . str_replace('/', '_', $file);
                    $ssh->recvFile(
                        $action->remotePhalconAdminPath . $file,
                        $local_file
                    );
                }
            }

            echo '备份 ssh.php 文件...', PHP_EOL;
            copy(
                $action->path_prod_config_file,
                $pathBackup . 'ssh.php'
            );

            echo '完成备份 {', $pathBackup, '}', PHP_EOL;
        } elseif ($g->hasArgsWithKey('project')) {
            $project = $g->getArgsWithKey('project', '');
            if (empty($project)) {
                die('必须指定待推送的项目名称' . PHP_EOL);
            }
            $path_project = PATH_SRC . 'App/Projects/' . $project . '/';
            if (!is_dir($path_project)) {
                die('待推送项目不存在 {' . $project . '}' . PHP_EOL);
            }
            $ssh = new ActionProdServer($action->getConfig());
            $files = MyFileSystem::getFilesInDirectory($path_project, function ($path){
                return str_contains($path,'.git');
            });

            $remote_dir = $action->remotePhalconAdminPath . 'src/';
            $lastMtime = $action->getProjectMtime($project);
            foreach ($files as $file) {
                $mtime = filemtime($file);
                if ($mtime > $lastMtime) {
                    $remote_file = $remote_dir . str_replace(PATH_SRC, '', $file);
                    $ssh->sendFile($file, $remote_file);
                }
            }
            $action->updateProjectMtime($project);
            echo '上传项目完毕', PHP_EOL;
        }

        break;
    case 'help':
        echo "~~~~~~~~~~ HOW TO USE ~~~~~~~~~~", PHP_EOL;
        echo HelpInfo;
        echo PHP_EOL;
        break;
    default:
        die('unknown action!!' . PHP_EOL);
}

