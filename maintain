switch ($g->action) {
    case 'init':
        class ActionInit
        {
            public G $g;
            private bool $overwrite = false;

            public function __construct(G $g)
            {
                $this->g = $g;
                $port = $g->getArgsWithKey('port', 0, true);
                if ($port < 1) {
                    die('必须指定端口号 -port=9988' . PHP_EOL);
                }
                $g->maintainData['port'] = $port;

                $this->overwrite = $g->hasArgsWithKey('y');
            }

            public function createEnvFile(): void
            {
                global $testPrefix;
                $newEnvFilePath = PATH_ROOT . $testPrefix . '.env';
                if (file_exists($newEnvFilePath) && !$this->overwrite) {
                    echo '跳过文件 {' . $testPrefix . '.env}', PHP_EOL;
                } else {
                    $envContent = file_get_contents(PATH_ROOT . '.env.example');
                    $envContent = str_replace(
                        'OPEN_PORT=8071',
                        'OPEN_PORT=' . $this->g->maintainData['port'],
                        $envContent
                    );
                    $envContent = str_replace('APP_NAME=phax', 'APP_NAME=' . $this->g->projectName, $envContent);
                    file_put_contents($newEnvFilePath, $envContent);
                    echo '复制成功 {' . $testPrefix . '.env}', PHP_EOL;
                }
            }

            private function copyExample($example): void
            {
                global $testPrefix;
                if (!file_exists($example)) {
                    die('找不到文件:' . $example . PHP_EOL);
                }

                $info = pathinfo($example);
                $toName = $info['dirname'] . '/' . $testPrefix . str_replace('.example', '', $info['basename']);
                $title = str_replace(PATH_ROOT, '', $toName);

                if (file_exists($toName) && !$this->overwrite) {
                    echo '跳过文件 {' . $title . '}', PHP_EOL;
                    return;
                }


                if (copy($example, $toName)) {
                    echo '复制成功 {', $title . '}', PHP_EOL;
                }
            }

            public function copyFiles(): void
            {
                foreach (ActionInitFiles as $file) {
                    $this->copyExample(PATH_ROOT . $file);
                }
            }

            public function replaceDockerComposeImage(): void
            {
                global $testPrefix;
                $dcYaml = PATH_ROOT . $testPrefix . 'docker-compose.yaml';
                $g = $this->g;
                if ($g->hasArgsWithKey('cn') || (isset($g->maintainData['cn']) && $g->maintainData['cn'])) {
                    $dcYamlContent = file_get_contents($dcYaml);
