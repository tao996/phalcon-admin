class G
{
    public array $maintainData = [];
    public array $argsOptions = [];
    /**
     * 当前项目名称
     * @var string
     */
    public string $projectName = '';
    public string $action = '';

    public function __construct()
    {
        global $testPrefix;
        include_once PATH_SRC . 'tao996/phar/dotenv.phar';
        spl_autoload_register(function ($class) {
            if (str_starts_with($class, 'Phax\\')) {
                include_once PATH_SRC . 'tao996/' . str_replace('\\', '/', $class) . '.php';
            }
        });
        $this->projectName = pathinfo(PATH_ROOT, PATHINFO_BASENAME);
        $this->maintainData = $this->getMaintainTmp();
        $this->argsOptions = $this->loadKvArgs();
        $this->loadEnv();
        $testPrefix = $this->getArgsWithKey('prefix');
    }

    /**
     * 获取 .env 配置信息
     * @return void
     */
    private function loadEnv(): void
    {
        global $testPrefix;
        $dotenv = new Dotenv();
        if (!file_exists(PATH_ROOT . $testPrefix . '.env')) {
            return;
        }
        $dotenv->overload(PATH_ROOT . $testPrefix . '.env');
    }


    /**
     * 获取命令行中的 --key=value 或者 -key=value 或者 -key 参数
     * @return array
     */
    private function loadKvArgs(): array
    {
        global $argv;
        $args = $argv;
        array_shift($args); // 移除脚本名称

        $this->action = $args[0] ?? 'help';

        $options = [];
        foreach ($args as $item) {
            if (preg_match('/^(--?)([\w-]+)=(.*)$/', $item, $matches)) {
                $value = $matches[3];
                $key = ltrim($matches[2], "-");
                $options[$key] = $value;
            } elseif (preg_match('/^(--?)([\w-]+)$/', $item, $matches)) {
                $key = ltrim($matches[2], "-");
                $options[$key] = null;
            }
        }
        return $options;
    }


    /**
     * 获取当前命令所保存的配置信息，用于在无指定参数时使用
     * @return array
     */
    private function getMaintainTmp(): array
    {
        if (file_exists(PATH_MAINTAIN_tmp)) {
            return json_decode(file_get_contents(PATH_MAINTAIN_tmp), true);
        }
        return [];
    }

    /**
     * 保存命令行所指定的数据
     * @return void
     */
    function saveMaintainTmp(): void
    {
        file_put_contents(PATH_MAINTAIN_tmp, json_encode($this->maintainData));
    }

    /**
     * 命令行中是否存在参数
     * @param string $key
     * @return bool
     */
    public function hasArgsWithKey(string $key): bool
    {
        return array_key_exists($key, $this->argsOptions);
    }

    /**
     * 获取参数中的值
     * @param string $key
     * @param mixed $default
     * @param bool $int 是否转为整型
     * @return int|mixed|string
     */
    public function getArgsWithKey(string $key, mixed $default = '', bool $int = false): mixed
    {
        $data = $this->argsOptions[$key] ?? $this->maintainData[$key] ?? $default;
        return $int ? intval($data) : $data;
    }
}

