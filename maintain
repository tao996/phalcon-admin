    case 'clear':
        class ActionClear
        {
            public array $toDeleteFiles = [];
            public G $g;

            public function __construct(G $g)
            {
                $this->g = $g;
                foreach (array_merge(['.env.example'], ActionInitFiles) as $file) {
                    $this->toDeleteFiles[] = $this->reverseCopyExample(PATH_ROOT . $file);
                }
