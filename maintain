                    } else {
                        echo '复制失败 {', $toName . '}', PHP_EOL;
                        die();
                    }
                }
            }
        }

        $action = new ActionProd($g);
        $action->createProdSaveDir();

        if ($g->hasArgsWithKey('c')) {
