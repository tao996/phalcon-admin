        define('PATH_NGINX_SSL', PATH_ROOT . 'nginx/ssl/');

        class ActionProd
        {
            /**
             * 目录名称，默认为 default
             * @var string|int|mixed
             */
            public string $dir = '';
            public string $path_prod = PATH_ROOT . 'prod/';
            /**
             * 配置目录路径 `$path_prod.$dir`，默认 `PATH_ROOT.prod/default/`
             * @var string
             */
            public string $path_prod_save = '';
            /**
