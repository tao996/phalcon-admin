#!/usr/bin/env php
<?php
$testPrefix = 'local-test-'; // 用于测试

// 判断操作系统
const IS_WIN = PHP_OS_FAMILY === 'Windows';
const PATH_ROOT = __DIR__ . '/';
const PATH_SRC = __DIR__ . '/src/';
const PATH_MAINTAIN_tmp = __DIR__ . '/maintain.tmp.txt';

class G
{
    public array $maintainData = [];
    public array $argsOptions = [];
    public string $projectName = '';
    public string $action = '';

    public function __construct()
    {
        include_once __DIR__ . '/src/tao996/phar/dotenv.phar';
        spl_autoload_register(function ($class) {
            if (str_starts_with($class, 'Phax\\')) {
                include_once PATH_SRC . 'tao996/' . str_replace('\\', '/', $class) . '.php';
            }
        });
        $this->projectName = pathinfo(__DIR__, PATHINFO_BASENAME);
        $this->maintainData = $this->getMaintainTmp();
        $this->argsOptions = $this->loadKvArgs();
        $this->loadEnv();
    }

    /**
     * 获取 .env 配置信息
     * @return void
     */
    private function loadEnv(): void
    {
        global $testPrefix;
        $dotenv = new \Symfony\Component\Dotenv\Dotenv();
        if (!file_exists(__DIR__ . '/' . $testPrefix . '.env')) {
            return;
        }
        $dotenv->overload(__DIR__ . '/' . $testPrefix . '.env');
    }


    /**
     * 获取命令行中的 --key=value 或者 -key=value 或者 -key 参数
     * @return array
     */
    private function loadKvArgs(): array
    {
        global $argv;
        $args = $argv;
        array_shift($args); // 移除脚本名称

        $this->action = $args[0] ?? 'help';

        $options = [];
        foreach ($args as $item) {
            if (preg_match('/^(--?)([\w-]+)=(.*)$/', $item, $matches)) {
                $value = $matches[3];
                $key = ltrim($matches[2], "-");
                $options[$key] = $value;
            } elseif (preg_match('/^(--?)([\w-]+)$/', $item, $matches)) {
                $key = ltrim($matches[2], "-");
                $options[$key] = null;
            }
        }
        return $options;
    }


    /**
     * 获取当前命令所保存的配置信息，用于在无指定参数时使用
     * @return array
     */
    private function getMaintainTmp(): array
    {
        if (file_exists(PATH_MAINTAIN_tmp)) {
            return json_decode(file_get_contents(PATH_MAINTAIN_tmp), true);
        }
        return [];
    }

    /**
     * 保存命令行所指定的数据
     * @return void
     */
    function saveMaintainTmp(): void
    {
        file_put_contents(PATH_MAINTAIN_tmp, json_encode($this->maintainData));
    }

    /**
     * 命令行中是否存在参数
     * @param string $key
     * @return bool
     */
    public function hasArgsWithKey($key): bool
    {
        return array_key_exists($key, $this->argsOptions);
    }

    /**
     * 获取参数中的值
     * @param string $key
     * @param mixed $default
     * @param bool $int 是否转为整型
     * @return int|mixed|string
     */
    public function getArgsWithKey($key, $default = '', $int = false): mixed
    {
        $data = $this->argsOptions[$key] ?? $this->maintainData[$key] ?? $default;
        return $int ? intval($data) : $data;
    }

    /**
     * 读取指定的文件
     * @param string $filePath 文件路径
     * @param string $filterStart 不要读取以此字符开头的行
     * @return string
     */
    function readFileWith($filePath, $filterStart = '#'): string
    {
        $fileHandle = fopen($filePath, 'r');

        if ($fileHandle === false) {
            die("无法打开文件: $filePath");
        }

        $filteredLines = [];

        while (($line = fgets($fileHandle)) !== false) {
            $line = trim($line);
            if (!str_starts_with($line, $filterStart)) {
                $filteredLines[] = $line;
            }
        }

        fclose($fileHandle);
        return join(PHP_EOL, $filteredLines);
    }
}

$g = new G();

const ActionInitFiles = [
    // .env.example 手动生成
    'docker-compose.example.yaml',
    'php/php.example.ini',
    'php/supervisord.example.conf',

    'src/.env.example',
    'src/phpunit.example.xml',
    'src/config/config.example.php',
    'src/config/project.example.php'
];

switch ($g->action) {
    case 'init':
        class ActionInit
        {
            private bool $overwrite = false;

            public function __construct(public G $g)
            {
                $port = $g->getArgsWithKey('port', 0, true);
                if ($port < 1) {
                    die('必须指定端口号 -port=9988' . PHP_EOL);
                }
                $g->maintainData['port'] = $port;

                $this->overwrite = $g->hasArgsWithKey('y');
            }

            public function createEnvFile(): void
            {
                global $testPrefix;
                $newEnvFilePath = __DIR__ . '/' . $testPrefix . '.env';
                if (file_exists($newEnvFilePath) && !$this->overwrite) {
                    echo '跳过文件 {' . $testPrefix . '.env}', PHP_EOL;
                } else {
                    $envContent = file_get_contents(__DIR__ . '/.env.example');
                    $envContent = str_replace(
                        'OPEN_PORT=8071',
                        'OPEN_PORT=' . $this->g->maintainData['port'],
                        $envContent
                    );
                    $envContent = str_replace('APP_NAME=phax', 'APP_NAME=' . $this->g->projectName, $envContent);
                    file_put_contents($newEnvFilePath, $envContent);
                    echo '复制成功 {' . $testPrefix . '.env}', PHP_EOL;
                }
            }

            private function copyExample($example): void
            {
                global $testPrefix;
                if (!file_exists($example)) {
                    die('找不到文件:' . $example . PHP_EOL);
                }

                $info = pathinfo($example);
                $toName = $info['dirname'] . '/' . $testPrefix . str_replace('.example', '', $info['basename']);
                $title = str_replace(__DIR__ . '/', '', $toName);

                if (file_exists($toName) && !$this->overwrite) {
                    echo '跳过文件 {' . $title . '}', PHP_EOL;
                    return;
                }


                if (copy($example, $toName)) {
                    echo '复制成功 {', $title . '}', PHP_EOL;
                }
            }

            public function copyFiles(): void
            {
                foreach (ActionInitFiles as $file) {
                    $this->copyExample(PATH_ROOT . $file);
                }
            }

            public function replaceDockerComposeImage(): void
            {
                global $testPrefix;
                $dcYaml = PATH_ROOT . $testPrefix . 'docker-compose.yaml';
                $g = $this->g;
                if ($g->hasArgsWithKey('cn') || (isset($g->maintainData['cn']) && $g->maintainData['cn'])) {
                    $dcYamlContent = file_get_contents($dcYaml);
                    $dcYamlContent = str_replace(
                        'image: authus/phalcon:',
                        'image: registry.cn-shenzhen.aliyuncs.com/authus/phalcon:',
                        $dcYamlContent
                    );
                    file_put_contents($dcYaml, $dcYamlContent);
                    $g->maintainData['cn'] = true;
                }
            }
        }

        $action = new ActionInit($g);
        $action->createEnvFile();
        $action->copyFiles();
        $action->replaceDockerComposeImage();

        echo 'SUCCESS.', PHP_EOL;
        break;
    case 'clear':
        class ActionClear
        {
            public array $toDeleteFiles = [];

            public function __construct(public G $g)
            {
                foreach (array_merge(['.env.example'], ActionInitFiles) as $file) {
                    $this->toDeleteFiles[] = $this->reverseCopyExample(PATH_ROOT . $file);
                }
            }

            private function reverseCopyExample($example): string
            {
                global $testPrefix;
                $info = pathinfo($example);
                return $info['dirname'] . '/' . $testPrefix . str_replace('.example', '', $info['basename']);
            }

            public function deleteFiles(): void
            {
                foreach ($this->toDeleteFiles as $file) {
                    if (file_exists($file)) {
                        $title = str_replace(PATH_ROOT, '', $file);
                        if (unlink($file)) {
                            echo '删除成功 {', $title, '}', PHP_EOL;
                        } else {
                            echo '删除失败 {', $title, '}', PHP_EOL;
                        }
                    } else {
                        echo '文件不存在 {', $file, '}', PHP_EOL;
                    }
                }
            }

            public function printDeleteFiles()
            {
                return array_map(function ($file) {
                    return str_replace(PATH_ROOT, '', $file);
                }, $this->toDeleteFiles);
            }
        }

        $action = new ActionClear($g);
        if ($g->hasArgsWithKey('y')) {
            $action->deleteFiles();
        } else {
            print_r($action->printDeleteFiles());
            echo '检查上面的文件，如果没有问题，则可使用 -y 进行删除', PHP_EOL;
        }
        break;
    case "backup":
        echo "TODO 备份外部数据库", PHP_EOL;
        break;
    case "prod":
        define('PATH_NGINX_SSL', PATH_ROOT . 'nginx/ssl/');

        class ActionProd
        {
            private string $dir = '';
            private string $path_prod_ssh_json_file = '';

            public string $path_prod_save = '';
            public string $path_prod_host_file = '';
            public array $files = [
                '.env.example',
                'docker-compose.example.yaml',
                'php/php.example.ini',
                'php/supervisord.example.conf',
                'src/.env.example',
                'src/config/config.example.php',
                'src/config/project.example.php',
                'src/config/migration.example.php',
                'nginx/sites/default.example.conf',
            ];
            public array $nginxFiles = []; // 站点配置
            /**
             * @return array{ip:string,port:int,username:string,password:string,public_ssh_key:string,private_ssh_key:string,path:string,nginx:string,
             *     certs:array{key:string,pem:string},hosts:array{string}}
             */
            private array $sshCC = [];
            public string $remotePhalconAdminPath = '';
            public string $remoteNginxConf = '';

            public function __construct(public G $g)
            {
                $this->dir = $g->getArgsWithKey('dir', 'default');
                $this->path_prod_save = __DIR__ . '/prod/' . $this->dir . '/';
                $this->path_prod_host_file = $this->path_prod_save . $g->projectName . '.conf';
                $this->path_prod_ssh_json_file = $this->path_prod_save . 'ssh.json';

                $this->nginxFiles = [
                    ['nginx/host.example.conf', $g->projectName . '.conf'],
                    ['nginx/host.location.example.conf', $g->projectName . '.location.conf']
                ];
            }

            /**
             * 获取 $this->files 在本地文件路径
             * @param string|array{string,string} $file
             * @return string
             */
            public function getLocalFile($file)
            {
                if (is_array($file)) {
                    return $this->path_prod_save . $file[1];
                }
                return $this->path_prod_save . str_replace('/', '_', str_replace('.example', '', $file));
            }

            /**
             * 获取 $this->files 在远程文件路径
             * @param string $remotePath
             * @param string|array{string,string} $file
             * @return string
             */
            public function getRemoteFile($remotePath, $file)
            {
                if (is_array($file)) {
                    return $remotePath . $file[1];
                }
                return $remotePath . str_replace('.example', '', $file);
            }

            /**
             * @return array{ip:string,port:int,username:string,password:string,public_ssh_key:string,private_ssh_key:string,path:string,nginx:string,
             *     certs:array{key:string,pem:string},hosts:array{string}}
             */
            public function getSshJson(): array
            {
                if (empty($this->sshCC)) {
                    if (!file_exists($this->path_prod_save)) {
                        die('目录不存在 ' . $this->path_prod_save . PHP_EOL);
                    }
                    $this->sshCC = json_decode(file_get_contents($this->path_prod_ssh_json_file), true);
                    $this->remotePhalconAdminPath = rtrim($this->sshCC['path'], '/') . '/';
                    $this->remoteNginxConf = rtrim($this->sshCC['nginx'] ?? '/etc/nginx/cond.f') . '/';
                }
                return $this->sshCC;
            }

            public function getCerts()
            {
                $certs = [];
                foreach ($this->sshCC['certs'] ?? [] as $cert) {
                    $file = PATH_ROOT . 'nginx/ssl/' . $cert;
                    if (is_file($file) && file_exists($file)) {
                        $certs[] = $cert;
                    }
                }
                return $certs;
            }

            public function getHosts()
            {
                return $this->sshCC['hosts'] ?? [];
            }

            public function createSshJson()
            {
                // 合并 ssh.json 文件
                $sshData = [
                    'ip' => '',
                    'port' => 22,
                    'username' => '',
                    'password' => '',
                    'public_ssh_key' => '',
                    'private_ssh_key' => '',
                    'path' => 'path/of/phalcon-admin',
                    'nginx' => '/etc/nginx/conf.d/',
                    'certs' => ['key' => '', 'pem' => ''], // 上传到 nginx 目录的证书，要保存在 nginx/ssl 目录下
                    'hosts' => [], // 添加到 /etc/hosts 的域名列表；示例 [a1.test,www.a1.test]
                ];
                if (file_exists($this->path_prod_ssh_json_file)) {
                    $sshData = array_merge(
                        $sshData,
                        json_decode(file_get_contents($this->path_prod_ssh_json_file), true)
                    );
                }
                file_put_contents($this->path_prod_ssh_json_file, json_encode($sshData));
            }

            public function createProdSaveDir()
            {
                if (is_dir($this->path_prod_save)) {
                    $hasFiles = glob($this->path_prod_save . '*');
                    if ($this->g->hasArgsWithKey('c')) {
                        if ($hasFiles && !$this->g->hasArgsWithKey('y')) {
                            die('{prod/' . $this->dir . '} 目录不为空；如需覆盖请追加参数 -y' . PHP_EOL);
                        }
                    } elseif (!$hasFiles) {
                        die('{prod/' . $this->dir . '} 目录为空，请先使用参数 -c 使用' . PHP_EOL);
                    }
                } else {
                    mkdir($this->path_prod_save);
                }
            }

            public function createFiles(): void
            {
                foreach (array_merge($this->files, $this->nginxFiles) as $file) {
                    if (is_string($file)) {
                        $toName = str_replace('.example', '', $file);
                    } else {
                        $toName = $file[1];
                        $file = $file[0];
                    }
                    $pathToName = $this->path_prod_save . str_replace('/', '_', $toName);
                    if (copy(PATH_ROOT . $file, $pathToName)) {
