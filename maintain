            private function reverseCopyExample($example): string
            {
                global $testPrefix;
                $info = pathinfo($example);
                return $info['dirname'] . '/' . $testPrefix . str_replace('.example', '', $info['basename']);
            }

            public function deleteFiles(): void
            {
                foreach ($this->toDeleteFiles as $file) {
                    if (file_exists($file)) {
                        $title = str_replace(PATH_ROOT, '', $file);
                        if (unlink($file)) {
                            echo '删除成功 {', $title, '}', PHP_EOL;
                        } else {
                            echo '删除失败 {', $title, '}', PHP_EOL;
                        }
                    } else {
                        echo '文件不存在 {', $file, '}', PHP_EOL;
                    }
                }
            }

            public function printDeleteFiles(): array
            {
                return array_map(function ($file) {
                    return str_replace(PATH_ROOT, '', $file);
                }, $this->toDeleteFiles);
            }
        }

        $action = new ActionClear($g);
        if ($g->hasArgsWithKey('y')) {
            $action->deleteFiles();
        } else {
