            $action->createSshJson();

            echo "生成完毕，请修改你的 ssh.json，然后再次执行命令 `php maintain prod -r -y`，将自动更新配置", PHP_EOL;
        } elseif ($g->hasArgsWithKey('r')) {
            class ActionProdReplace
            {

                public function __construct(public ActionProd $prod)
                {
                    if (!file_exists($this->prod->path_prod_save . 'ssh.json')) {
                        die('ssh.json 文件不存在');
                    }
                    $this->prod->getSshJson();
                }

                // 更改 host 文件中的 xxx.test
                function replaceNginxHost(): void
                {
                    $hostContent = file_get_contents($this->prod->path_prod_host_file);

                    $domains = $this->prod->getHosts();

                    // phalcon-admin.conf
                    // 1。替换域名
                    if ($domains) {
                        $dbDomains = array_map(function ($domain) {
                            return str_starts_with($domain, 'www.')
                                ? str_replace('www.', 'www.db-', $domain)
                                : 'db-' . $domain;
                        }, $domains);
                        $hostContent = str_replace('db-xxx.test', join(' ', $dbDomains), $hostContent);
                        $hostContent = str_replace('xxx.test', join(' ', $domains), $hostContent);
                        echo '替换域名成功 {', $this->prod->g->projectName, '.conf}', PHP_EOL;
                    }
                    $phpmyadminPort = $_ENV['PHPMYADMIN_PORT'] ?? 0;
                    if ($phpmyadminPort > 0) {
                        $hostContent = str_replace(':5456', ':' . $phpmyadminPort, $hostContent);
                        echo '替换 db 端口成功', PHP_EOL;
                    }
                    // 2。替换 include
                    $hostContent = str_replace(
                        'include host.location.example.conf;',
                        'include conf.d/' . $this->prod->g->projectName . '.location.conf',
                        $hostContent
                    );
                    // 3. 替换证书
                    $certs = $this->prod->getCerts();
                    if ($certs) {
                        if (!empty($certs['key'])) {
                            $hostContent = str_replace('xxx.key', $certs['key'], $hostContent);
                            echo '替换 key 证书成功', PHP_EOL;
                        }
                        if (!empty($certs['pem'])) {
                            $hostContent = str_replace('xxx.pem', $certs['pem'], $hostContent);
                            echo '替换 pem 证书成功', PHP_EOL;
                        }
                    }
                    file_put_contents($this->prod->path_prod_host_file, $hostContent);

                    // phalcon-admin.location.conf
                    if ($port = $this->getPort()) {
                        $path_location_file = $this->prod->path_prod_save . $this->prod->g->projectName . '.location.conf';
                        $locationContent = file_get_contents($path_location_file);
                        $locationContent = str_replace(':8071', ':' . $port, $locationContent);
                        file_put_contents($path_location_file, $locationContent);
                        echo '替换端口成功 {', $this->prod->g->projectName . '.location.conf', '}', PHP_EOL;
                    }
                }

                public function getPort()
                {
                    $port = intval($this->prod->g->maintainData['port'] ?? 0);
                    return $port > 0 && $port != 8071 ? $port : 0;
                }

                public function replaceEnv()
                {
                    if ($port = $this->getPort()) {
                        $envContent = file_get_contents($this->prod->path_prod_save . '.env');
                        $envContent = str_replace('OPEN_PORT=8071', 'OPEN_PORT=' . $port, $envContent);
                        file_put_contents($this->prod->path_prod_save . '.env', $envContent);
                    }
                }
            }

            $replace = new ActionProdReplace($action);
            $replace->replaceEnv();
            $replace->replaceNginxHost();

            echo '替换完成', PHP_EOL;
        }

        class ActionProdServer
        {

            private mixed $ssh;

            public function __construct(public array $config)
            {
                if (!function_exists('ssh2_connect')) {
                    die('请安装 ssh2 扩展' . PHP_EOL);
                }
                $this->validate();
            }

            private function validate(): void
            {
                if (empty($this->config['path'])) {
                    die('必须指定远程保存地址 ssh.json->path');
                }
                if (empty($this->config['ip'])) {
                    die('必须指定 ssh ip 地址' . PHP_EOL);
                } elseif (empty($this->config['username'])) {
                    die('必须指定 ssh username' . PHP_EOL);
                } elseif (empty($this->config['password']) && (empty($this->config['public_ssh_key']) || empty($this->config['private_ssh_key']))) {
                    die('必须指定密码或者登录证书');
                }
            }


            private function connect()
            {
                if (empty($this->ssh)) {
                    if (!$this->ssh = ssh2_connect($this->config['ip'], $this->config['port'] ?? 22)) {
                        die('SSH validation failed for IP:' . $this->config['ip'] . PHP_EOL);
                    }

                    if (!empty($this->config['password'])) {
                        if (!ssh2_auth_password($this->ssh, $this->config['username'], $this->config['password'])) {
                            die("SSH validation failed using Username: " . $this->config['username'] . " (specify valid password)");
                        }
                    } else {
                        if (!ssh2_auth_pubkey_file(
                            $this->ssh,
                            $this->config['username'],
                            $this->config['public_ssh_key'],
                            $this->config['private_ssh_key']
                        )) {
                            die("SSH validation failed using Username: " . $this->config['username'] . " (specify valid SSH keys or check your SSH key path)");
                        }
                    }
                    echo 'SSH connect success...', PHP_EOL;
                }
            }

            public function sendCommand($command): string|false
            {
                $this->connect();
                $stream = ssh2_exec($this->ssh, $command);
                stream_set_blocking($stream, true);
                return stream_get_contents($stream);
            }


            public function sendFile($local_file, $remote_file, $print = true): bool
            {
                $this->connect();
                if (!file_exists($local_file)) {
                    die('文件不存在 {' . $local_file . '}' . PHP_EOL);
                }
                $rst = ssh2_scp_send($this->ssh, $local_file, $remote_file, 0644);
                if ($print) {
                    if ($rst) {
                        echo '上传成功 {', $remote_file, '}', PHP_EOL;
                    } else {
                        echo '本地文件:', $local_file, PHP_EOL;
                        echo '远程文件:', $remote_file, PHP_EOL;
                        throw new \Exception('上传失败');
                    }
                }
                return $rst;
            }

            public function recvFile($remote_file, $local_file, $print = true): bool
            {
                $this->connect();
                $rst = ssh2_scp_recv($this->ssh, '"' . $remote_file . '"', $local_file);
                if ($print) {
                    if ($rst) {
                        echo '获取成功 {', $remote_file, '}', PHP_EOL;
                    } else {
                        echo '获取失败 {', $remote_file, '}', PHP_EOL;
                    }
                }
                return $rst;
            }

            private mixed $sftp;

            private function connectSFTP()
            {
                if (empty($this->sftp)) {
                    $this->connect();
                    $this->sftp = ssh2_sftp($this->ssh);
                }
            }

            public function unlink($remote_file, $print = true): bool
            {
                $this->connectSFTP();
                $rst = ssh2_sftp_unlink($this->sftp, $remote_file);
                if ($print) {
                    if ($rst) {
                        echo '移除成功 {', $remote_file, '}', PHP_EOL;
                    } else {
                        echo '移除失败 {', $remote_file . '}', PHP_EOL;
                    }
                }
                return $rst;
            }


        }

        if ($g->hasArgsWithKey('u')) {
            $ssh = new ActionProdServer($action->getSshJson());

            $uValue = $g->getArgsWithKey('u', '*');

            if (in_array($uValue, ['*', 'app'])) {
                echo '准备上传项目配置文件...', PHP_EOL;
                foreach ($action->files as $file) {
                    $local_file = $action->getLocalFile($file);
                    $remote_file = $action->getRemoteFile($action->remotePhalconAdminPath, $file);
                    $ssh->sendFile($local_file, $remote_file);
                }
            }
            if (in_array($uValue, ['*', 'nginx'])) {
                if (empty($ssh->sendCommand('which nginx'))) {
                    die("nginx 还没有安装作" . PHP_EOL);
                }
                echo '准备上传站点文件到 nginx...', PHP_EOL;
                foreach ($action->nginxFiles as $files) {
                    $ssh->sendFile(
                        $action->path_prod_save . $files[1],
                        $action->remoteNginxConf . $files[1]
                    );
                }

                echo '准备上传证书到 nginx...', PHP_EOL;
                foreach ($action->getCerts() as $cert) {
                    $ssh->sendFile(
                        PATH_NGINX_SSL . $cert,
                        $action->remoteNginxConf . $cert
                    );
                }
            }
            if (in_array($uValue, ['*', 'hosts', 'host'])) {
                echo '准备处理 /etc/hosts...', PHP_EOL;
                $content = $ssh->sendCommand('cat /etc/hosts');
                $appendHosts = [];
                foreach ($action->getHosts() as $host) {
                    if (!str_contains($content, $host)) {
                        $appendHosts[] = '127.0.0.1 ' . $host;
                    }
                }
                if (!empty($appendHosts)) {
                    $cmd = 'echo "' . join(PHP_EOL, $appendHosts) . PHP_EOL . '" >> /etc/hosts';
                    $ssh->sendCommand($cmd);
                    echo '写入完成 /etc/hosts', PHP_EOL;
                }
            }
        } elseif ($g->hasArgsWithKey('del')) {
            $ssh = new ActionProdServer($action->getSshJson());

            $dValue = $g->getArgsWithKey('del', '*');
            if (in_array($dValue, ['*', 'app'])) {
                echo '准备移除项目配置文件...', PHP_EOL;
                foreach ($action->files as $file) {
                    $remote_file = $action->getRemoteFile($action->remotePhalconAdminPath, $file);
                    $ssh->unlink($remote_file);
                }
            }
            if (in_array($dValue, ['*', 'nginx'])) {
                echo '准备移除配置到 nginx 的文件...', PHP_EOL;
                foreach ($action->nginxFiles as $files) {
                    $remote_file = $action->remoteNginxConf . $files[1];
                    $ssh->unlink($remote_file);
                }
                if ($certs = $action->getCerts()) {
                    echo '准备移除配置到 nginx 的证书...', PHP_EOL;
                    foreach ($certs as $cert) {
                        $remote_file = $action->remoteNginxConf . $cert;
                        $ssh->unlink($remote_file);
                    }
                }
            }
            if (in_array($dValue, ['*', 'hosts', 'host'])) {
                echo '准备移除 /etc/hosts 域名配置信息 ...', PHP_EOL;
                $hosts = $action->getHosts();
                if (!empty($hosts)) {
                    $content = $ssh->sendCommand('cat /etc/hosts');
                    if (str_contains($content, '"')) {
                        die('/etc/hosts 中包含双引号，请手动替换' . PHP_EOL);
                    }
                    foreach ($hosts as $host) {
                        $content = str_replace('127.0.0.1 ' . $host, '', $content);
                    }
                    $content = preg_replace('/\n{2,}/', "\n", $content);
                    $cmd = 'echo "' . $content . '" >> /etc/hosts';
                    $ssh->sendCommand($cmd);
                    echo '更新完成 /etc/hosts', PHP_EOL;
                }
            }
        }
        break;
    case 'help':
        echo "~~~~~~~~~~ HOW TO USE ~~~~~~~~~~", PHP_EOL;
        echo <<<HELP
-y : 默认情况下如果 nginx 目录下存在着站点的配置文件，则不会自动生成

php maintain init       # 根据当前目录初始化环境
    -port=Num   : nginx 反代的端口号；示例 -port=8090
    -cn         : 使用 aliyun image 镜像，适用于 CN
    -y          : 覆盖已存在的文件
php maintain clear      # 删除由 maintain 生成的文件
    -y          : 确定删除，如果不提供则参数，则会打印待删除的文件
php maintain prod       # 将应用配置文件生成到 prod 目录下
    -dir[=Str]   : 保存目录，默认为 default；如果目录存在
    -c           : create 全部配置文件到 prod 目录，并生成 ssh.json 文件
    -y           : 覆盖已经存在的配置文件（ssh.json 不会被覆盖）
    -r           : 使用 ssh.json 的信息来更新配置文件中的默认信息
    -u[=Str]     : 将 -dir 目录下的配置文件 upload 到 ssh.json 中服务器指定的项目位置；注意：需要安装 ssh2 扩展， apt install php8.2-ssh2 ssh
                   默认值为 *，表示同时上传 app, nginx, hosts
                   app   上传应用相关的配置文件
                   nginx 上传 nginx 相关的配置文件
                   hosts 修改 /etc/hosts 文件
    -del[=Str]   : 移除 -u 所上传的文件，默认值为 *，可选值为 app|nginx|hosts
    -d           : 下载 ssh.json 中远程项目的配置文件下载到 -dir 指定的本地目录，保存时到自动追加日期
HELP;
        echo PHP_EOL;
        break;
    default:
        die('unknown action!!' . PHP_EOL);
}

$g->saveMaintainTmp();

